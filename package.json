{
  "name": "thesislens",
  "version": "0.1.0",
  "private": true,
  "description": "Rules-based U.S. equity research workspace powered by FMP data.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "smoke": "node scripts/smoke.mjs",
